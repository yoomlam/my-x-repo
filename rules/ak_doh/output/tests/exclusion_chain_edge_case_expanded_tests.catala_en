  definition result.irregular_earned_income equals $0
  definition result.student_earned_income equals $0
  definition result.student_monthly_limit equals $0
  definition result.non_needs_based_unearned_remainder equals $20
  definition result.impairment_work_expenses equals $115
  definition result.blind_work_expenses equals $0
  definition result.self_support_exclusion equals $0
